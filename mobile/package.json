{
  "name": "rent",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint \"{app,src}/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"{app,src}/**/*.{ts,tsx}\" \"*.{js,json}\"",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.js",
    "test:cov": "jest --config jest.config.js --coverage",
    "e2e:prebuild": "npx expo prebuild --platform android --no-install",
    "e2e:build:android": "detox build -c android.emu.debug",
    "e2e:test:android": "sh scripts/e2e-android-test.sh",
    "e2e:android": "npm run e2e:build:android && npm run e2e:test:android",
    "format:check": "prettier --check \"{app,src}/**/*.{ts,tsx}\" \"*.{js,json}\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/react-query": "^5.101.2",
    "base-64": "^1.0.0",
    "expo": "~56.0.13",
    "expo-constants": "~56.0.19",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.19",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-modules-core": "~56.0.18",
    "expo-router": "~56.2.12",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.19",
    "expo-status-bar": "~56.0.4",
    "i18next": "^26.3.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "detox": "^20.47.0",
    "eslint": "^10.6.0",
    "globals": "^17.3.0",
    "jest": "~29.7.0",
    "jest-circus": "~29.7.0",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "private": true
}
