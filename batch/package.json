{
  "name": "batch",
  "version": "1.0.0",
  "description": "Batch billing system for rent management platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "bin": {
    "billing-batch": "dist/index.js"
  },
  "scripts": {
    "build": "rm -f *.tsbuildinfo && npx tsc -p tsconfig.build.json --outDir ./dist --listEmittedFiles",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.42.0",
    "@pyroscope/nodejs": "^0.5.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.18.1",
    "commander": "^15.0.0",
    "dotenv": "^17.2.4",
    "handlebars": "^4.7.9",
    "newrelic": "14.2.0",
    "node-forge": "^1.3.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "soap": "^1.6.4",
    "typeorm": "^1.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/node-forge": "^1.3.14",
    "@types/pdfkit": "^0.17.4",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "overrides": {
    "@nestjs/core": {
      "path-to-regexp": "8.4.0"
    },
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "2.0.3"
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "esModuleInterop": true,
          "allowSyntheticDefaultImports": true
        }
      }
    },
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(node-html-parser|entities)/)"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "lines": 80,
        "functions": 80,
        "branches": 70
      }
    }
  }
}
